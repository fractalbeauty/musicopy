---
interface Props {
  src: string;
  alt: string;
  side: "left" | "right";
  /**
   * `app`: border and background color
   * `transparent`: no border or background color
   */
  mode: "app" | "transparent";
}

const { src, alt, side, mode } = Astro.props;

const border = mode === "app";
const backgroundColor = mode === "app";

const classes = [
  side === "left" ? "left" : "right",
  border ? "border" : "",
  backgroundColor ? "background-color" : "",
].join(" ");
---

<img src={src} alt={alt} class={classes} />

<style>
  img.border {
    border: 1px solid var(--color-outline-variant);
  }
  img.background-color {
    background-color: var(--color-secondary-container);
  }

  .left {
    float: left;
    max-height: 300px;
    margin-right: 16px;
    margin-bottom: 16px;
  }
  .right {
    float: right;
    max-height: 300px;
    margin-left: 16px;
    margin-bottom: 16px;
  }
  @media screen and (max-width: 800px) {
    .left,
    .right {
      width: 50%;
    }
  }
</style>
