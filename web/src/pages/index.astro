---
import BaseLayout from "../components/BaseLayout.astro";
import FilledButtonLink from "../components/FilledButtonLink.astro";
import Footer from "../components/Footer.astro";
import InfoTiles from "../components/fragments/InfoTiles.astro";
import ManualInstructions from "../components/fragments/ManualInstructions.astro";
import Main from "../components/Main.astro";
import Nav from "../components/Nav.astro";
---

<BaseLayout title="Musicopy">
  <Nav logotypeElement="h1" />

  <Main>
    <div class="hero">
      <div class="hero-desktop">
        <img src="/static/hero_desktop.png" />
      </div>
      <div class="hero-mobile">
        <img src="/static/hero_mobile.png" />
      </div>
    </div>

    <div class="tagline">
      <h2>Transfer your music to your phone, without the hassle.</h2>
      <div class="cta">
        <FilledButtonLink href="/download" size="lg"
          >Download Musicopy</FilledButtonLink
        >
      </div>
    </div>

    <ManualInstructions includeDownloadTiles={false} />

    <div class="tagline">
      <FilledButtonLink href="/download" size="lg">
        <div class="row">
          Try Musicopy&nbsp;

          <span class="material-symbols-outlined"> arrow_forward </span>
        </div>
      </FilledButtonLink>
    </div>
  </Main>

  <div class="flex-1"></div>

  <Footer />

  <style>
    .hero {
      display: flex;
      flex-direction: row;
      justify-content: center;
      gap: calc(min(800px, 100vw - 40px) * 0.05);
      margin: 20px 0;
    }

    .hero-desktop {
      /* width: calc(min(800px, 100vw - 40px) * 0.7); */
      background-color: var(--color-secondary-container);
      border: 1px solid var(--color-outline-variant);
    }
    .hero-mobile {
      /* width: calc(min(800px, 100vw - 40px) * 0.25); */
      background-color: var(--color-secondary-container);
      border: 1px solid var(--color-outline-variant);
    }

    .hero img {
      display: block;
      max-width: 100%;
      max-height: 100%;
    }

    .tagline {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      margin: 40px 0;
    }

    .tagline h2 {
      margin: 0;
      padding: 0;
    }

    hr {
      border: none;
      border-top: 1px solid var(--color-outline-variant);
      margin: 40px 16px;
    }

    .row {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 8px;
    }
  </style>
</BaseLayout>
